{
  "name": "TidyWorld Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/tidyworld",
  "forwardPorts": [27017, 6333, 6334],
  "portsAttributes": {
    "27017": {
      "label": "MongoDB",
      "onAutoForward": "silent"
    },
    "6333": {
      "label": "Qdrant REST",
      "onAutoForward": "silent"
    },
    "6334": {
      "label": "Qdrant gRPC",
      "onAutoForward": "silent"
    }
  },
  "containerEnv": {
    "MONGODB_URI": "mongodb://mongodb:27017/tidyworld",
    "QDRANT_URL": "http://qdrant:6333",
    "OLLAMA_HOST": "http://host.docker.internal:11434",
    "OPENAI_BASE_URL": "http://host.docker.internal:11434/v1",
    "OPENAI_API_KEY": "ollama"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.black-formatter",
        "njpwerner.autodocstring",
        "tamasfe.even-better-toml",
        "ms-python.mypy-type-checker",
        "cweijan.vscode-database-client2"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/tidyworld/.venv/bin/python",
        "python.linting.enabled": true,
        "python.formatting.provider": "black",
        "[python]": {
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": true,
            "source.fixAll": true
          }
        },
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      }
    }
  },
  "postCreateCommand": "uv sync --group dev",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": false,
      "installOhMyZsh": true,
      "upgradePackages": true,
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "ppa": true,
      "version": "os-provided"
    }
  }
}
